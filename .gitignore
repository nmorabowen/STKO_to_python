# Ignore Python bytecode
__pycache__/
*.py[cod]

# Ignore Python packaging files
*.egg-info/
/dist/
/build/
src/STKO_to_python/examples/log.log
log.log

# MkDocs build output (generated by `mkdocs build`)
/site/

# pytest-benchmark storage (generated by `pytest bench/`)
/.benchmarks/

# Large MPCO fixtures kept developer-local (~2 GB each). Tests that
# depend on these skip gracefully via their conftest fixtures, so a
# clean clone still runs the suite green. Obtain them from the
# original STKO export to enable the corresponding tests locally.
stko_results_examples/Test_NLShell/
