# Ignore Python bytecode
__pycache__/
*.py[cod]

# Ignore Python packaging files
*.egg-info/
/dist/
/build/
src/STKO_to_python/examples/log.log
log.log

# MkDocs build output (generated by `mkdocs build`)
/site/

# pytest-benchmark storage (generated by `pytest bench/`)
/.benchmarks/

# Claude Code worktrees and session metadata. The harness creates
# these per-session and they should never be staged.
.claude/

# Large fixtures kept out of git history. The smaller checked-in
# fixtures under stko_results_examples/elasticFrame/ are still tracked
# and integration tests use them; this larger fixture is developer-
# local. Tests that depend on it skip gracefully when absent (see
# tests/conftest.py::solid_partition_dir). Obtain the .mpco / .cdata
# files from the original STKO export and place them under this path
# to enable the corresponding tests locally.
stko_results_examples/solid_partition_example/
